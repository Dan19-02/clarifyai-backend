# Copy to .env and set your real key
# NEVER commit your real key to source control.
MINIMAX_API_KEY=nvapi-REPLACE_WITH_YOUR_KEY
# Optional: override the API URL
#MINIMAX_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
# ---- Backend configuration ----
PORT=4000

# Allowed browser origin for CORS (the frontend dev server). "*" to allow all.
CORS_ORIGIN=http://localhost:3000

# PostgreSQL connection string. Examples:
#   Local:  postgresql://postgres:postgres@localhost:5432/clarify
#   Neon:   postgresql://USER:PASS@ep-xxx.aws.neon.tech/clarify?sslmode=require
# Free cloud Postgres in ~2 min: https://neon.tech  (or Supabase / Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clarify

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Gemini (Standard mode, TTS, image diagrams, live voice, Search grounding)
GEMINI_API_KEY=

# Open-source teaching brain (Standard + Thinking). Any OpenAI-compatible API.
#
# Current dev setup: MiniMax-M3 via the NVIDIA NIM free tier. That tier queues
# unpredictably (20s to 200s+ for identical requests), which is the measured
# cause of multi-minute answers. The fix is a paid endpoint; MiniMax's own API
# is OpenAI-compatible, so switching is config only, no code change:
#   OPENSOURCE_BASE_URL=<base URL from your MiniMax console, e.g. https://api.minimax.io/v1>
#   OPENSOURCE_API_KEY=<your MiniMax key>
#   OPENSOURCE_MODEL=<model id from the MiniMax console, e.g. MiniMax-M3>
#   OPENSOURCE_TIMEOUT_MS=20000
OPENSOURCE_BASE_URL=
OPENSOURCE_API_KEY=
OPENSOURCE_MODEL=

# How long to wait for the open-source brain before falling back to Gemini.
# Default 45000 (45s) suits the flaky free tier; on a paid plan use ~20000.
OPENSOURCE_TIMEOUT_MS=45000
