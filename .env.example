# ---- Backend configuration ----
PORT=4000

# Allowed browser origin for CORS (the frontend dev server). "*" to allow all.
CORS_ORIGIN=http://localhost:3000

# PostgreSQL connection string. Examples:
#   Local:  postgresql://postgres:postgres@localhost:5432/clarify
#   Neon:   postgresql://USER:PASS@ep-xxx.aws.neon.tech/clarify?sslmode=require
# Free cloud Postgres in ~2 min: https://neon.tech  (or Supabase / Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clarify

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Gemini (Standard mode, TTS, image diagrams, live voice, Search grounding)
GEMINI_API_KEY=

# Optional open-source model (Thinking mode + Search-writer). OpenAI-compatible.
# e.g. MiniMax-M3 via NVIDIA NIM, or Groq/Together/Fireworks/OpenRouter/vLLM/Ollama.
OPENSOURCE_BASE_URL=
OPENSOURCE_API_KEY=
OPENSOURCE_MODEL=
